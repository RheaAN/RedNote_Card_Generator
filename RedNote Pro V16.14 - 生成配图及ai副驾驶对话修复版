            if (type === 'funnel') return `<div class="flex flex-col items-center justify-center w-full h-[300px] gap-1">${items.map((item,i)=>`<div class="flex items-center justify-center font-bold" style="width:${100-(i/items.length)*80}%; height:${100/items.length}%; background:${alpha(1-(i*0.15))}; clip-path: polygon(0 0, 100% 0, 90% 100%, 10% 100%); font-size:${textSize}px; color:${textColor}">${item}</div>`).join('')}</div>`;
            if (type === 'timeline') return `<div class="flex flex-col justify-center h-full w-full px-8 py-4">${lines.map(line=>{let parts=line.split(/[:：]/);let time=parts[0];let event=parts[1]||"";if(!event){event=time;time=""}return `<div class="timeline-item" style="border-color:${shapeColor}; color:${textColor}"><div class="timeline-dot" style="background:${shapeColor}"></div>${time?`<div class="font-black opacity-60" style="font-size:${Math.max(10,textSize-2)}px">${time}</div>`:''}<div class="font-bold leading-tight" style="font-size:${textSize}px">${event}</div></div>`}).join('')}</div>`;
            if (type === 'mandala') return `<div class="grid grid-cols-3 gap-1 w-full aspect-square p-4">${Array.from({length:9}).map((_,i)=>{const isCenter=i===4;return `<div class="flex items-center justify-center p-1 text-center font-bold rounded break-all shadow-sm" style="background:${isCenter?shapeColor:alpha(0.1)}; color:${isCenter?'#fff':textColor}; font-size:${textSize}px">${items[i]||''}</div>`}).join('')}</div>`;
            if (type === 'vs') { const rows=lines.slice(1); const [tA,tB]=lines[0]?lines[0].split(/[|｜]/):['A','B']; return `<div class="w-full h-full flex flex-col justify-center px-4"><div class="flex justify-between font-black mb-6 text-center" style="font-size:${textSize+4}px; color:${textColor}"><div class="w-1/2 border-b-4 pb-2" style="border-color:${shapeColor}">${tA}</div><div class="opacity-30 px-2 flex items-end pb-2 italic font-serif">VS</div><div class="w-1/2 border-b-4 pb-2" style="border-color:${alpha(0.5)}">${tB}</div></div><div class="flex-1 flex flex-col gap-2">${rows.map(row=>{const [a,b]=row.split(/[|｜]/);return `<div class="flex justify-between py-2 border-b border-dashed items-center" style="border-color:${alpha(0.2)}; font-size:${textSize}px; color:${textColor}"><div class="w-1/2 pr-4 text-right opacity-80">${a||''}</div><div class="w-1/2 pl-4 text-left font-bold">${b||''}</div></div>`}).join('')}</div></div>`; }
            if (type === 'iceberg') { return `<div class="relative w-full h-[350px] flex flex-col items-center justify-center"><div class="absolute w-full h-[2px] top-[35%] z-0" style="background:${shapeColor}; opacity:0.3; border-bottom: 2px dashed ${shapeColor}"></div><div class="absolute right-4 top-[35%] mt-[-20px] text-xs font-bold opacity-50" style="color:${textColor}">看不见的</div><div class="absolute right-4 top-[35%] mt-[10px] text-xs font-bold opacity-50" style="color:${textColor}">看得见的</div><div class="absolute top-[50px] w-40 h-24 bg-red-500 z-0" style="background:${alpha(0.8)}; clip-path: polygon(50% 0, 0% 100%, 100% 100%);"></div><div class="absolute top-[146px] w-64 h-48 bg-blue-500 z-0" style="background:${alpha(0.4)}; clip-path: polygon(0 0, 100% 0, 80% 100%, 20% 100%);"></div><div class="absolute top-[90px] z-10 text-center font-bold text-white w-full flex justify-center pointer-events-none" style="font-size:${textSize}px; color:${textColor}; text-shadow:0 1px 2px rgba(255,255,255,0.8)">${items[0]||'行为'}</div><div class="absolute top-[180px] z-10 text-center font-bold text-white w-full flex justify-center pointer-events-none" style="font-size:${textSize}px; color:${textColor}; text-shadow:0 1px 2px rgba(255,255,255,0.8)">${items[1]||'潜意识'}</div></div>`; }
            return `<div class="text-xs">${rawData}</div>`;
        }

        // --- FEATURE 1: Import CSV (From V16.3) ---
        function handleImportCSV(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    try {
                        const csvText = e.target.result;
                        const rows = parseCSV(csvText);
                        
                        // 🛡️ 增加空值检查 (微调重点)
                        if (!rows || rows.length < 2) throw new Error("CSV 文件为空或格式错误");
                        if (!rows[0] || !rows[1]) throw new Error("CSV 数据行不完整");

                        const headers = rows[0].map(h => (h ? h.trim() : '')); // 防止 header 有 null
                        const row = rows[1];
                        
                        const getVal = (key) => { const idx = headers.indexOf(key); return idx !== -1 ? (row[idx] || '') : ''; }; // 增加 row[idx] 的非空保护

                        document.getElementById('input-title').value = getVal('Title');
                        document.getElementById('input-author').value = getVal('Author');
                        document.getElementById('input-vol').value = getVal('Volume');
                        document.getElementById('input-content').value = getVal('Content'); 
                        document.getElementById('input-chart-data').value = getVal('ChartData');
                        document.getElementById('ai-eng-title').value = getVal('AI_Keywords');

                        setSelectByText('select-chart', getVal('ChartType'));
                        setSelectByText('ai-style-select', getVal('AI_Style'));
                        setSelectByText('ai-view-select', getVal('AI_View'));

                        updateState();
                        updateChartPlaceholder();
                        alert("✅ 数据导入成功！");
                    } catch (err) {
                        console.error(err);
                        alert("导入失败: " + err.message + "\n请检查 CSV 文件格式。");
                    }
                    input.value = '';
                };
                reader.readAsText(input.files[0]);
            }
        }
        function parseCSV(text) {
            const rows = []; let row = []; let curVal = ''; let inQuote = false;
            for (let i = 0; i < text.length; i++) {
                const c = text[i]; const next = text[i+1];
                if (inQuote) { if (c === '"' && next === '"') { curVal += '"'; i++; } else if (c === '"') { inQuote = false; } else { curVal += c; } } 
                else { if (c === '"') { inQuote = true; } else if (c === ',') { row.push(curVal); curVal = ''; } else if (c === '\r') { } else if (c === '\n') { row.push(curVal); rows.push(row); row = []; curVal = ''; } else { curVal += c; } }
            }
            if (curVal || row.length) { row.push(curVal); rows.push(row); }
            return rows;
        }
        function setSelectByText(selectId, text) {
            if (!text) return;
            const select = document.getElementById(selectId);
            for (let i = 0; i < select.options.length; i++) { if (select.options[i].text === text || select.options[i].value === text) { select.selectedIndex = i; break; } }
        }

        // --- FEATURE 2: Export Fix (From V16.3) ---
        async function downloadZip() {
            const btn = document.getElementById('dl-btn'); 
            const originalText = btn.innerHTML; 
            btn.innerHTML = '⏳ 打包中...'; 
            btn.disabled = true;
            
            try { // 添加 try 包裹整个逻辑，防止报错卡死
                const zip = new JSZip(); 
                const cards = document.querySelectorAll('.preview-card');
                
                const txtContent = `Project: ${state.title}\nAuthor: ${state.author}\nDate: ${new Date().toLocaleString()}\n\n[Content]\n${state.content}\n\n[Chart Data]\n${state.chartData}`;
                zip.file("readme.txt", txtContent);

                // --- 🛡️ 安全获取数据 (微调重点) ---
                const safeVal = (id) => { const el = document.getElementById(id); return el ? el.value : ''; };
                const safeText = (id) => { 
                    const el = document.getElementById(id); 
                    // 只有当元素存在，且有选中的项时，才获取 text，否则返回空字符串
                    return (el && el.options && el.selectedIndex >= 0) ? el.options[el.selectedIndex].text : ''; 
                };

                const aiKeywords = safeVal('ai-eng-title');
                const aiStyle = safeText('ai-style-select');
                const aiView = safeText('ai-view-select');
                const chartType = safeText('select-chart');

                const q = (str) => `"${(str || '').replace(/"/g, '""')}"`; 
                
                const csvContent = `\ufeffTitle,Author,Volume,Content,ChartType,ChartData,AI_Keywords,AI_Style,AI_View\n${q(state.title)},${q(state.author)},${q(state.vol)},${q(state.content)},${q(chartType)},${q(state.chartData)},${q(aiKeywords)},${q(aiStyle)},${q(aiView)}`;
                zip.file("project_data.csv", csvContent);

                let chatLog = "=== RedNote Copilot Chat History ===\n\n";
                if (chatState.history && chatState.history.length > 0) { chatState.history.forEach((msg, idx) => { const role = msg.role === 'user' ? '👤 User' : '🤖 AI'; chatLog += `[${role}]:\n${msg.content}\n${'-'.repeat(40)}\n\n`; }); } else chatLog += "No conversation history.";
                zip.file("chat_history.txt", chatLog);

                const sandbox = document.createElement('div');
                sandbox.style.position = 'absolute'; sandbox.style.top = '-9999px'; sandbox.style.left = '0';
                sandbox.style.width = '375px'; sandbox.style.zIndex = '-1';
                document.body.appendChild(sandbox);

                for (let i = 0; i < cards.length; i++) {
                    const originalCard = cards[i];
                    const clonedCard = originalCard.cloneNode(true);
                    clonedCard.style.transform = 'none'; clonedCard.style.margin = '0'; clonedCard.style.boxShadow = 'none';
                    sandbox.innerHTML = ''; sandbox.appendChild(clonedCard);
                    const canvas = await html2canvas(clonedCard, { scale: 3, useCORS: true, allowTaint: true, backgroundColor: null, logging: false, scrollY: 0, scrollX: 0 });
                    const blob = await new Promise(r => canvas.toBlob(r, 'image/png'));
                    zip.file(`RedNote_${i+1}.png`, blob);
                }
                document.body.removeChild(sandbox);
                
                const content = await zip.generateAsync({type:"blob"});
                saveAs(content, "RedNote_V16_9_Package.zip");

            } catch (err) { 
                console.error(err); 
                alert("打包失败: " + err.message); 
            } finally { 
                btn.innerHTML = originalText; 
                btn.disabled = false; 
            }
        }
        // 👇 [TRAE 追加]: 系统提示词的持久化保存逻辑 (就放在这里！) 👇
        function saveSystemPrompt() {
            const promptVal = document.getElementById('ai-system-prompt').value;
            localStorage.setItem('rn_system_prompt', promptVal);
        }
        init();
    </script>

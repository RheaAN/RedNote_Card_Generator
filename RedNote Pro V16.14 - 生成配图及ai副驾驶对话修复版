        async function sendChatMessage() {
            // 1. 获取输入
            const input = document.getElementById('chatInput'); 
            const text = input.value.trim(); 
            if(!text && !chatState.currentImageBase64) return;
            
            // 2. 界面显示
            let userDisplay = text; 
            if(chatState.currentImageBase64) {
                userDisplay = `<img src="data:image/jpeg;base64,${chatState.currentImageBase64}" class="chat-img-preview" style="max-width: 150px; border-radius: 8px; display: block; margin-bottom: 5px;"><div style="white-space: pre-wrap;">${text}</div>`;
            }
            addMessage('user', userDisplay);
            chatState.history.push({ role: 'user', content: text, hasImage: !!chatState.currentImageBase64 });
            localStorage.setItem('rn_chat_history', JSON.stringify(chatState.history));
            
            // 3. 锁定按钮
            input.value = ''; 
            const btn = document.getElementById('chatSendBtn');
            btn.disabled = true; 
            const loadingId = addLoading();

            try {
                // 4. 准备上下文
                const safeVal = (id) => { const el = document.getElementById(id); return el ? el.value : ''; };
                const currentContext = `
[System Context]
- Title: "${safeVal('input-title').replace(/\n/g, ' ')}"
- Content: ${safeVal('input-content')}
- Theme: ${state.theme}
You are RedNote Copilot.
`;
                // 强制合并 System Prompt 到 User 消息，解决 API 兼容问题
                const finalPrompt = `${currentContext}\n\nUser Question: ${text}`;
                let replyText = "";
                
                // 5. 发送请求
                if (chatState.mode === 'google') {
                    const keyEl = document.getElementById('cp-key-google');
                    const modelEl = document.getElementById('cp-model-google');
                    const key = keyEl ? keyEl.value.trim() : '';
                    const model = modelEl ? modelEl.value : 'gemini-1.5-pro';
                    
                    if(!key) throw new Error("请在【右侧副驾面板】输入 Gemini Key"); 
                    localStorage.setItem('gemini_key', key);
                    
                    const parts = [{ text: finalPrompt }];
                    // [TRAE 修复]: 动态使用真实的 MIME Type
                    if (chatState.currentImageBase64) {
                        parts.push({ inline_data: { mime_type: chatState.currentImageMime || "image/jpeg", data: chatState.currentImageBase64 } });
                    }
                    
                    const resp = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${key}`, { 
                        method: 'POST', headers: { 'Content-Type': 'application/json' }, 
                        body: JSON.stringify({ contents: [{ parts: parts }] }) 
                    });
                    
                    const data = await resp.json(); 
                    if(data.error) throw new Error("Google API 报错: " + data.error.message);
                    if(!data.candidates) throw new Error("API 未返回内容");
                    replyText = data.candidates[0].content.parts[0].text;

                } else {
                    // Claude/GPT 模式
                    const keyEl = document.getElementById('cp-key-custom');
                    const baseEl = document.getElementById('cp-base-url');
                    const key = keyEl ? keyEl.value.trim() : '';
                    const base = baseEl ? baseEl.value.replace(/\/$/, '') : '';
                    
                    let model = document.getElementById('cp-model-select').value;
                    if (model === 'custom') model = document.getElementById('cp-model-custom').value;
                    
                    if(!key) throw new Error("请在【右侧副驾面板】输入 API Key"); 
                    localStorage.setItem('rn_key_custom', key);
                    
                    // [TRAE 核心修复]: 如果有图片，按照 OpenAI/Claude 视觉模型标准重构 Payload
                    let messagesPayload;
                    if (chatState.currentImageBase64) {
                        messagesPayload = [{
                            role: "user", 
                            content: [
                                { type: "text", text: finalPrompt },
                                { type: "image_url", image_url: { url: `data:${chatState.currentImageMime || 'image/jpeg'};base64,${chatState.currentImageBase64}` } }
                            ]
                        }];
                    } else {
                        messagesPayload = [{role:"user", content: finalPrompt}];
                    }

                    const resp = await fetch(`${base}/chat/completions`, { 
                        method: 'POST', headers: {'Content-Type': 'application/json', 'Authorization': `Bearer ${key}`}, 
                        body: JSON.stringify({ model: model, messages: messagesPayload }) 
                    });
                    
                    const data = await resp.json(); 
                    if(data.error) {
                        const errMsg = typeof data.error === 'string' ? data.error : data.error.message;
                        throw new Error("API 报错: " + errMsg);
                    }
                    replyText = data.choices[0].message.content;
                }
                
                removeLoading(loadingId); 
                addMessage('model', marked.parse(replyText)); 
                chatState.history.push({ role: 'model', content: replyText }); 
                localStorage.setItem('rn_chat_history', JSON.stringify(chatState.history));

            } catch(e) { 
                removeLoading(loadingId); 
                console.error(e);
                // 🛑 错误直接弹窗，如果有问题你会立刻看到！
